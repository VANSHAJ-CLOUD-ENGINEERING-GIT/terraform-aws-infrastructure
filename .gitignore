# ==========================================
# Terraform
# ==========================================

# Local Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==========================================
# Terraform Variables
# ==========================================

# Ignore sensitive variable files
terraform.tfvars
*.auto.tfvars

# Keep the example file
!example.tfvars

# ==========================================
# AWS Credentials & Keys
# ==========================================

*.pem
*.ppk
*.key

# ==========================================
# IDE Files
# ==========================================

.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Operating System Files
# ==========================================

.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================

*.log

# ==========================================
# Temporary Files
# ==========================================

tmp/
temp/
*.tmp
